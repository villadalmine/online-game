# Copy to .env and adjust. All config is 12-factor (env-driven).
APP_NAME="Online Galaxy War"
ENVIRONMENT=development

# Database (async SQLAlchemy URL). Postgres in prod/dev; sqlite for quick local runs/tests.
DATABASE_URL=postgresql+asyncpg://game:game@localhost:5432/game
# DATABASE_URL=sqlite+aiosqlite:///./game.db

# Redis (cache + rate-limit). Optional: si REDIS_ENABLED=false todo degrada a no-op.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
CATALOG_CACHE_TTL=300
ATTACK_RATE_LIMIT_PER_MIN=20

# Auth
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Game balance (overridable without code changes)
ENERGY_REGEN_PER_HOUR=10
ENERGY_MAX=240
ENERGY_START=60

# Combat balance
ATTACK_ENERGY_COST=25
LOOT_FRACTION=0.2
TRAVEL_SECONDS_SAME_PLANET=60
TRAVEL_SECONDS_CROSS_PLANET=300

# World auto-tick (segundos): el mundo avanza solo. 0 = apagado (usar CronJob en prod multi-réplica).
AUTO_TICK_SECONDS=0

# NPC (razas controladas por IA)
NPC_ENABLED=true
NPC_BRAIN=rules                 # rules (default) | llm (cualquier server OpenAI-compatible)

# LLM para NPCs (NPC_BRAIN=llm). Cualquier endpoint OpenAI-compatible:
#   OpenRouter:  LLM_BASE_URL=https://openrouter.ai/api/v1  LLM_MODEL=google/gemma-4-31b-it:free  LLM_API_KEY=sk-or-...
#   Ollama:      LLM_BASE_URL=http://localhost:11434/v1     LLM_MODEL=llama3.1:8b                 LLM_API_KEY=ollama
#   LiteLLM:     LLM_BASE_URL=http://litellm:4000/v1        LLM_MODEL=npc-brain                   LLM_API_KEY=sk-litellm-...
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
LLM_JSON_MODE=true              # pide response_format=json_object (más robusto); apagá si tu server no lo soporta

# Compat: si no seteás LLM_*, se usan estos OPENROUTER_* como fallback.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free
