# Copy to .env and adjust. All config is 12-factor (env-driven).
APP_NAME="Online Galaxy War"
ENVIRONMENT=development

# Database (async SQLAlchemy URL). Postgres in prod/dev; sqlite for quick local runs/tests.
DATABASE_URL=postgresql+asyncpg://game:game@localhost:5432/game
# DATABASE_URL=sqlite+aiosqlite:///./game.db

# Redis (cache + rate-limit). Optional: si REDIS_ENABLED=false todo degrada a no-op.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
CATALOG_CACHE_TTL=300
ATTACK_RATE_LIMIT_PER_MIN=20

# Auth
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Game balance (overridable without code changes)
ENERGY_REGEN_PER_HOUR=10
ENERGY_MAX=240
ENERGY_START=60

# Combat balance
ATTACK_ENERGY_COST=25
LOOT_FRACTION=0.2
TRAVEL_SECONDS_SAME_PLANET=60
TRAVEL_SECONDS_CROSS_PLANET=300

# World auto-tick (segundos): el mundo avanza solo. 0 = apagado (usar CronJob en prod multi-réplica).
AUTO_TICK_SECONDS=0

# NPC (razas controladas por IA)
NPC_ENABLED=true
NPC_BRAIN=rules                 # rules (default) | llm (OpenRouter, opcional)
# OPENROUTER_API_KEY=sk-or-...  # solo si NPC_BRAIN=llm
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemma-4-31b-it:free
